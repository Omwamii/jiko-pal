{
  "expo": {
    "name": "jikopal",
    "slug": "jikopal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "deeplinking": true,
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Jiko Pal needs local network access to configure your LPG tank sensor.",
        "NSLocationWhenInUseUsageDescription": "Jiko Pal uses your location to show nearby vendors/clients and to support deliveries and sensor setup."
      },
      "bundleIdentifier": "com.anonymous.jikopal"
    },
    "android": {
      "usesCleartextTraffic": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "NEARBY_WIFI_DEVICES",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.jikopal",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "react-native-wifi-reborn",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/fire-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#5E60CE"
        }
      ],
      [
        "expo-notifications",
        {
          "androidMode": "production",
          "iosModes": [
            "development",
            "production"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f87a97f0-84d4-480d-877a-fc17d31a333b"
      }
    },
    "owner": "omwami"
  }
}
